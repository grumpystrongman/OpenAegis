{
  "name": "openaegis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "Enterprise Agent Orchestration and Trust Platform",
  "workspaces": [
    "backend/services/*",
    "backend/shared/*",
    "frontend/apps/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test",
    "test:commercial": "npm run build && node --test --test-concurrency=1 tests/commercial/commercial-proof.test.mjs tests/commercial/trust-layer-proof.test.mjs tests/commercial/readiness-gate-score.test.mjs tests/commercial/project-packs-showcase.test.mjs",
    "lint": "npm run --workspaces lint",
    "validate:infra": "node tools/scripts/validate-infra.mjs",
    "validate:test-surface": "node tools/scripts/validate-test-surface.mjs",
    "typecheck": "npm run --workspaces typecheck",
    "smoke:pilot": "node tools/scripts/smoke-pilot.mjs",
    "run:tool-registry": "npm run --workspace @openaegis/tool-registry build && node tools/scripts/run-tool-registry.mjs",
    "proof:commercial": "npm run build && node tools/scripts/commercial-proof.mjs",
    "showcase:projects": "npm run build && node tools/scripts/commercial-projects-showcase.mjs",
    "proof:trust-layer": "npm run build && node tools/scripts/prove-trust-layer.mjs",
    "security:regression": "node tools/scripts/security-regression.mjs",
    "vuln:dependencies": "node tools/scripts/vuln-scan-dependencies.mjs",
    "trust:pack": "node tools/scripts/generate-enterprise-trust-pack.mjs",
    "trust:audit": "node tools/scripts/audit-enterprise-trust-pack.mjs",
    "audit:codebase": "node tools/scripts/codebase-line-audit.mjs",
    "audit:commercial": "node tools/scripts/commercial-audit.mjs",
    "pilot:local": "node tools/scripts/local-pilot.mjs",
    "pilot:kpis": "node tools/scripts/design-partner-kpis.mjs",
    "pilot:design-partners": "npm run proof:trust-layer && npm run pilot:kpis",
    "challenge:launch": "node tools/scripts/launch-trust-proof-challenge.mjs",
    "evidence:security-pack": "node tools/scripts/security-evidence-pack.mjs",
    "load:commercial": "node tools/scripts/load-commercial.mjs",
    "chaos:commercial": "node tools/scripts/chaos-commercial.mjs",
    "backup:state": "node tools/scripts/backup-state.mjs",
    "restore:state": "node tools/scripts/restore-state.mjs",
    "evidence:package": "node tools/scripts/export-evidence-package.mjs",
    "readiness:gate": "node tools/scripts/readiness-gate.mjs",
    "screenshots:commercial": "node tools/scripts/capture-commercial-screenshots.mjs",
    "sandbox:list": "node tools/scripts/sandbox-compose.mjs list",
    "sandbox:config": "node tools/scripts/sandbox-compose.mjs config --all",
    "sandbox:up": "node tools/scripts/sandbox-compose.mjs up",
    "sandbox:down": "node tools/scripts/sandbox-compose.mjs down",
    "sandbox:ps": "node tools/scripts/sandbox-compose.mjs ps",
    "sandbox:proof": "npm run build && node tools/scripts/sandbox-proof.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "playwright": "^1.58.2",
    "typescript": "^5.8.3",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
